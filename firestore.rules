rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: solo el propio usuario puede leer/escribir su doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Proyectos: solo el owner
      match /projects/{projectId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Piezas del proyecto: solo el owner
        match /pieces/{pieceId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // Caché de inventarios de sets: cualquier usuario auth puede leer y crear (primera vez)
    // El caché es inmutable — no se puede actualizar ni eliminar
    match /sets/{setId}/pieces/{pieceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // MOCs de comunidad: cualquiera puede leer (es contenido público), solo auth puede crear
    match /community_projects/{mocId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 80;
      // El autor puede actualizar solo imageUrl (el upload se hace después del create)
      // Cualquier auth puede incrementar cloneCount
      // Solo el autor puede borrar su MOC
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.authorId
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cloneCount', 'likeCount', 'status']));
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;

      // Piezas del MOC: cualquiera puede leer, solo el autor puede escribir
      match /pieces/{pieceId} {
        allow read: if true;
        allow write: if request.auth != null
                     && request.auth.uid == get(/databases/$(database)/documents/community_projects/$(mocId)).data.authorId;
      }

      // Likes: cualquier usuario auth puede crear/borrar su propio like
      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Reportes: solo el usuario auth puede crear el suyo, nadie puede leer/editar
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
